#!/usr/bin/env bash
# Flow stdin lines into N columns, column-major (down first, then across).
# Designed for tmux panes showing lists of nodes/jobs that overflow vertically.
#
# Usage: command | colmajor [cols] [colwidth]
#   cols     defaults to 3
#   colwidth defaults to floor(terminal_width / cols)
#
# Why not pr -T -N? pr re-encodes runs of spaces as TAB chars to save bytes,
# but the terminal expands tabs to fixed 8-char stops that don't match cpustat's
# %-Ns padding, so the rendered output mis-aligns. This script writes literal
# spaces only — no tabs — so what awk computes is what the terminal shows.
set -u

cols="${1:-3}"
termwidth="$(tput cols 2>/dev/null || echo 240)"
colwidth="${2:-$((termwidth / cols))}"

awk -v cols="$cols" -v width="$colwidth" '
{ items[NR] = $0 }
END {
    n = NR
    rows = int((n + cols - 1) / cols)
    for (r = 1; r <= rows; r++) {
        line = ""
        for (c = 0; c < cols; c++) {
            i = r + c * rows
            if (i <= n) {
                v = items[i]
                if (length(v) > width) v = substr(v, 1, width)
                line = line sprintf("%-*s", width, v)
            }
        }
        sub(/[ \t]+$/, "", line)
        print line
    }
}'
