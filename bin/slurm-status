#!/usr/bin/env bash
# Output a one-line Slurm summary for tmux status line. Cached 10s.
set -u
CACHE="/tmp/slurm-status-${USER}.cache"
TTL=10

if [[ -f "$CACHE" ]] && [[ $(( $(date +%s) - $(stat -c %Y "$CACHE" 2>/dev/null || echo 0) )) -lt $TTL ]]; then
    cat "$CACHE"
    exit 0
fi

# Format: R:<running> PD:<pending>  — silent if squeue fails or no jobs.
out="$(squeue --me --noheader -o '%t' 2>/dev/null \
    | awk 'BEGIN{r=0;p=0} {if($1=="R")r++; else if($1=="PD")p++} END{
        if(r==0 && p==0) print "";
        else if(p==0) printf "[R:%d]", r;
        else printf "[R:%d PD:%d]", r, p
      }')"

printf '%s' "$out" > "$CACHE"
printf '%s' "$out"
