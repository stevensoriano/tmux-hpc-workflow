#!/usr/bin/env bash
# gpustat — per-node GPU view from Slurm: model, mem/GPU, system RAM, and who is
# using each GPU node. Requires squeue/sinfo/scontrol; the model->mem table covers
# common NVIDIA cards (extend as needed).
set -u

USER_MAP=$(squeue -h -t R -o "%N|%u" 2>/dev/null | awk -F'|' '
{ cmd="scontrol show hostnames \""$1"\" 2>/dev/null"
  while ((cmd|getline n)>0) {
    k=n SUBSEP $2
    if (!(k in s)) { m[n]=m[n](m[n]?",":"")$2; s[k]=1 }
  }
  close(cmd) }
END { for (n in m) print n"\t"m[n] }')

sinfo -N -o "%20N %10t %25G %10m" 2>/dev/null | awk -v um="$USER_MAP" '
BEGIN { mem["m4000"]="8GB GDDR5"; mem["p100"]="16GB HBM2"
        mem["v100"]="32GB HBM2"; mem["a100"]="40GB HBM2e"
        n=split(um,L,"\n"); for(i=1;i<=n;i++) if(L[i]!=""){split(L[i],p,"\t");u[p[1]]=p[2]} }
NR==1 { printf "%-18s %-10s %-12s %-12s %-10s %s\n",
               "NODE","STATE","GPU","MEM/GPU","SYS-RAM","USERS"; next }
/gpu:/ { if (match($3,/gpu:([a-z0-9]+):([0-9]+)/,a)) {
    printf "%-18s %-10s %-12s %-12s %dGB %s\n",
           $1,$2,a[2]"x "toupper(a[1]),mem[a[1]],int($4/1024),
           (u[$1]!=""?u[$1]:"-") } }'
